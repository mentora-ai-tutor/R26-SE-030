              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "auth", "logout"]
            },
            "description": "Logout the current user (requires authentication)"
          },
          "response": [
            {
              "name": "Success Response",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Logged out successfully\",\n  \"data\": null\n}"
            },
            {
              "name": "Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"success\": false,\n  \"error\": \"Access denied. No token provided.\",\n  \"code\": \"NO_TOKEN\"\n}"
            }
          ]
        }
