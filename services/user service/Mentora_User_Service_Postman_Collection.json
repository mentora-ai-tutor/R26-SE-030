              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"success\": false,\n  \"error\": \"Refresh token expired\",\n  \"code\": \"REFRESH_TOKEN_EXPIRED\"\n}"
            },
            {
              "name": "Invalid Refresh Token",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"success\": false,\n  \"error\": \"Invalid refresh token\",\n  \"code\": \"INVALID_REFRESH_TOKEN\"\n}"
            }
