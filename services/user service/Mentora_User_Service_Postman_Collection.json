              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"securepassword123\",\n  \"profile\": {\n    \"java_level\": \"beginner\",\n    \"institution\": \"SLIIT\",\n    \"country\": \"Sri Lanka\"\n  }\n}"
            },
            "url": {
              "raw": "http://localhost:3001/api/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "auth", "register"]
            },
            "description": "Register a new student. Rate limited to 20 requests per 15 minutes."
          },
          "response": [
            {
              "name": "Success Response",
              "originalRequest": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"securepassword123\"\n}"
                }
              },
              "status": "Created",
              "code": 201,
              "body": "{\n  \"success\": true,\n  \"message\": \"Registration successful\",\n  \"data\": {\n    \"student\": {\n      \"student_id\": \"STD-00001\",\n      \"name\": \"John Doe\",\n      \"email\": \"john.doe@example.com\",\n      \"role\": \"student\",\n      \"profile\": {\n        \"java_level\": \"beginner\",\n        \"institution\": \"SLIIT\",\n        \"country\": \"Sri Lanka\",\n        \"avatar_url\": \"\",\n        \"bio\": \"\"\n      },\n      \"stats\": {\n        \"overall_mastery_score\": 0,\n        \"total_materials_generated\": 0,\n        \"total_sessions\": 0,\n        \"last_mastery_update\": null\n      },\n      \"is_active\": true,\n      \"enrolled_at\": \"2026-04-14T10:30:00.000Z\",\n      \"last_active\": \"2026-04-14T10:30:00.000Z\"\n    },\n    \"access_token\": \"eyJhbGciOiJIUzI1NiIs...\",\n    \"refresh_token\": \"eyJhbGciOiJIUzI1NiIs...\",\n    \"expires_in\": \"1h\"\n  }\n}"
            },
            {
              "name": "Email Already Exists",
              "originalRequest": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"existing@example.com\",\n  \"password\": \"securepassword123\"\n}"
                }
              },
              "status": "Conflict",
              "code": 409,
              "body": "{\n  \"success\": false,\n  \"error\": \"Email already registered\",\n  \"code\": \"EMAIL_EXISTS\"\n}"
            },
            {
              "name": "Validation Error",
              "originalRequest": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"J\",\n  \"email\": \"invalid-email\",\n  \"password\": \"123\"\n}"
                }
              },
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"error\": \"Name must be at least 2 characters, Please provide a valid email address, Password must be at least 6 characters\",\n  \"code\": \"VALIDATION_ERROR\"\n}"
            }
