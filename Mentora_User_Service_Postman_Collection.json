            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{access_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/internal/auth/verify",
              "host": ["{{base_url}}"],
              "path": ["internal", "auth", "verify"]
            },
            "description": "Verify JWT token validity"
