    {
      "name": "Mastery Profiles",
      "item": [
        {
          "name": "POST /api/mastery/submit",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 202 Accepted', function() {",
                  "    pm.response.to.have.status(202);",
                  "});",
                  "",
                  "pm.test('Returns job_id and data', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "    pm.expect(jsonData.data).to.have.property('job_id');",
                  "    pm.expect(jsonData.data).to.have.property('student_id');",
                  "    pm.expect(jsonData.data).to.have.property('gaps_queued');",
                  "    pm.expect(jsonData.data).to.have.property('topics');",
                  "    pm.expect(jsonData.data).to.have.property('check_status_at');",
                  "    pm.expect(jsonData.data).to.have.property('materials_available_at');",
                  "});",
                  "",
                  "pm.test('Correct student_id in response', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.student_id).to.eql(pm.variables.get('studentId'));",
                  "});",
                  "",
                  "pm.test('Job ID format is correct', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.job_id).to.match(/^JOB_\\d+$/);",
                  "});",
                  "",
                  "pm.collectionVariables.set('jobId', pm.response.json().data.job_id);"
                ]
              }
            }
          ],
