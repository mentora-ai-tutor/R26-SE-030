    {
      "name": "02. Authentication",
      "description": "Authentication endpoints. Rate limited: 20 requests per 15 minutes",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"securepassword123\",\n  \"profile\": {\n    \"java_level\": \"beginner\",\n    \"institution\": \"SLIIT\",\n    \"country\": \"Sri Lanka\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Register a new user. Student ID auto-generated as STD-XXXXX."
          },
          "response": [
            {
              "name": "Success",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"success\": true,\n  \"message\": \"Registration successful. Please verify your email.\",\n  \"data\": {\n    \"student\": {\n      \"student_id\": \"STD-00001\",\n      \"name\": \"John Doe\",\n      \"email\": \"john.doe@example.com\",\n      \"role\": \"student\",\n      \"profile\": {\n        \"java_level\": \"beginner\",\n        \"institution\": \"SLIIT\",\n        \"country\": \"Sri Lanka\",\n        \"avatar_url\": \"\",\n        \"bio\": \"\"\n      },\n      \"stats\": {\n        \"overall_mastery_score\": 0,\n        \"total_materials_generated\": 0,\n        \"total_sessions\": 0,\n        \"last_mastery_update\": null\n      },\n      \"is_active\": true,\n      \"is_verified\": false,\n      \"preferences\": {\n        \"notifications\": {\n          \"email\": true,\n          \"push\": true,\n          \"marketing\": false\n        },\n        \"theme\": \"system\",\n        \"language\": \"en\",\n        \"timezone\": \"UTC\"\n      },\n      \"enrolled_at\": \"2026-04-15T10:30:00.000Z\",\n      \"last_active\": \"2026-04-15T10:30:00.000Z\"\n    },\n    \"access_token\": \"eyJhbGciOiJIUzI1NiIs...\",\n    \"refresh_token\": \"eyJhbGciOiJIUzI1NiIs...\",\n    \"expires_in\": \"1h\",\n    \"requires_verification\": true\n  }\n}"
            },
            {
              "name": "Email Already Exists",
              "status": "Conflict",
              "code": 409,
              "body": "{\n  \"success\": false,\n  \"error\": \"Email already registered\",\n  \"code\": \"EMAIL_EXISTS\"\n}"
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"securepassword123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login with email and password. Account locks after 5 failed attempts for 15 minutes."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Success\",\n  \"data\": {\n    \"student\": {\n      \"student_id\": \"STD-00001\",\n      \"name\": \"John Doe\",\n      \"email\": \"john.doe@example.com\",\n      \"role\": \"student\",\n      \"is_active\": true,\n      \"is_verified\": true,\n      \"profile\": {\n        \"java_level\": \"beginner\"\n      },\n      \"stats\": {\n        \"overall_mastery_score\": 75,\n        \"total_materials_generated\": 10,\n        \"total_sessions\": 5\n      }\n    },\n    \"access_token\": \"eyJhbGciOiJIUzI1NiIs...\",\n    \"refresh_token\": \"eyJhbGciOiJIUzI1NiIs...\",\n    \"session_token\": \"abc123def456...\",\n    \"expires_in\": \"1h\"\n  }\n}"
            },
            {
              "name": "Account Locked",
              "status": "Locked",
              "code": 423,
              "body": "{\n  \"success\": false,\n  \"error\": \"Account is locked. Please try again in 12 minutes.\",\n  \"code\": \"ACCOUNT_LOCKED\"\n}"
            },
            {
              "name": "Invalid Credentials",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"success\": false,\n  \"error\": \"Invalid email or password\",\n  \"code\": \"INVALID_CREDENTIALS\"\n}"
            },
            {
              "name": "Account Deactivated",
              "status": "Forbidden",
              "code": 403,
              "body": "{\n  \"success\": false,\n  \"error\": \"Account has been deactivated\",\n  \"code\": \"ACCOUNT_DEACTIVATED\"\n}"
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "refresh"]
            },
            "description": "Get a new access token using refresh token"
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Success\",\n  \"data\": {\n    \"access_token\": \"eyJhbGciOiJIUzI1NiIs...\",\n    \"expires_in\": \"1h\"\n  }\n}"
            },
            {
              "name": "Token Expired",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"success\": false,\n  \"error\": \"Refresh token expired\",\n  \"code\": \"REFRESH_TOKEN_EXPIRED\"\n}"
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"all_devices\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "logout"]
            },
            "description": "Logout current session. Set `all_devices: true` to logout from all devices."
          },
          "response": []
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/forgot-password",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "forgot-password"]
            },
            "description": "Request password reset. Always returns success to prevent email enumeration."
          },
          "response": [
            {
              "name": "Success (Generic)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"If an account exists, a password reset email has been sent\",\n  \"data\": null\n}"
            }
          ]
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"reset-token-from-email\",\n  \"new_password\": \"newsecurepassword456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/reset-password",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "reset-password"]
            },
            "description": "Reset password with token from email. Token expires in 1 hour."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Password reset successful. Please log in with your new password.\",\n  \"data\": null\n}"
            },
            {
              "name": "Invalid Token",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"error\": \"Invalid or expired reset token\",\n  \"code\": \"INVALID_TOKEN\"\n}"
            }
          ]
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"verification-token-from-email\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/verify-email",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "verify-email"]
            },
            "description": "Verify email address with token. Token expires in 24 hours."
          },
          "response": []
        },
        {
          "name": "Resend Verification",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/resend-verification",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "resend-verification"]
            },
            "description": "Resend verification email"
          },
          "response": []
        },
        {
          "name": "Get Sessions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/sessions",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "sessions"]
            },
            "description": "List all active sessions with device information"
          },
          "response": [
            {
              "name": "Sessions List",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Success\",\n  \"data\": {\n    \"sessions\": [\n      {\n        \"_id\": \"session-id-1\",\n        \"device_name\": \"Chrome on Windows\",\n        \"device_type\": \"desktop\",\n        \"os\": \"Windows\",\n        \"browser\": \"Chrome\",\n        \"ip_address\": \"192.168.1.1\",\n        \"is_active\": true,\n        \"last_active_at\": \"2026-04-15T10:30:00.000Z\",\n        \"createdAt\": \"2026-04-15T08:00:00.000Z\"\n      },\n      {\n        \"_id\": \"session-id-2\",\n        \"device_name\": \"Safari on iOS\",\n        \"device_type\": \"mobile\",\n        \"os\": \"iOS\",\n        \"browser\": \"Safari\",\n        \"ip_address\": \"192.168.1.2\",\n        \"is_active\": true,\n        \"last_active_at\": \"2026-04-14T18:00:00.000Z\"\n      }\n    ]\n  }\n}"
            }
          ]
        },
        {
          "name": "Revoke Session",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/sessions/{{session_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "sessions", "{{session_id}}"]
            },
            "description": "Revoke a specific session (logout from that device)"
          },
          "response": []
        }
      ]
    },
