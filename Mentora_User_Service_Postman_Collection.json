{
  "info": {
    "_postman_id": "mentora-user-service-v2-1",
    "name": "Mentora User Service API v2.1",
    "description": "Complete Postman collection for Mentora User Service with all advanced features.\n\n## Features\n- JWT Authentication with Refresh Tokens\n- Account Lockout (5 failed attempts = 15min lock)\n- Password Reset via Email Token\n- Email Verification\n- Multi-device Session Management\n- Soft Delete / Restore\n- Admin User Management\n- Bulk Operations\n- Audit Logging\n- Analytics & Metrics\n\n## Environment Variables Needed\n- `base_url`: http://localhost:3001\n- `access_token`: JWT token from login/register\n- `admin_token`: Admin user JWT token\n- `internal_service_key`: Key for internal service endpoints\n- `student_id`: Format STD-XXXXX (e.g., STD-00001)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01. Health & Monitoring",
      "description": "Public endpoints for health checks and system monitoring",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Check service health with detailed status including DB connection, memory usage, and uptime"
          },
          "response": [
            {
              "name": "Healthy Response",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{base_url}}/health"
                }
              },
              "status": "OK",
              "code": 200,
              "body": "{\n  \"service\": \"user-service\",\n  \"status\": \"ok\",\n  \"timestamp\": \"2026-04-15T10:30:00.000Z\",\n  \"uptime\": 3600,\n  \"version\": \"1.0.0\",\n  \"environment\": \"development\",\n  \"database\": {\n    \"status\": \"connected\",\n    \"name\": \"mentora_users\",\n    \"host\": \"localhost\"\n  },\n  \"memory\": {\n    \"used\": \"45MB\",\n    \"total\": \"128MB\"\n  }\n}"
            },
            {
              "name": "Unhealthy (DB Disconnected)",
              "status": "Service Unavailable",
              "code": 503,
              "body": "{\n  \"service\": \"user-service\",\n  \"status\": \"error\",\n  \"timestamp\": \"2026-04-15T10:30:00.000Z\",\n  \"database\": {\n    \"status\": \"disconnected\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Request Metrics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/metrics",
              "host": ["{{base_url}}"],
              "path": ["metrics"]
            },
            "description": "Get request metrics including response times, error rates, and route statistics"
          },
          "response": [
            {
              "name": "Metrics Response",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Success\",\n  \"data\": {\n    \"uptime\": 7200,\n    \"requests\": {\n      \"total\": 1250,\n      \"responses\": 1248,\n      \"errors\": 2,\n      \"error_rate\": \"0.16%\"\n    },\n    \"response_time\": {\n      \"avg\": 45,\n      \"p50\": 32,\n      \"p95\": 120,\n      \"p99\": 250\n    },\n    \"by_status\": {\n      \"200\": 1100,\n      \"201\": 100,\n      \"400\": 30,\n      \"401\": 15,\n      \"500\": 2\n    },\n    \"by_route\": {\n      \"POST /api/auth/login\": {\n        \"count\": 150,\n        \"errors\": 5,\n        \"avg_duration\": 85,\n        \"error_rate\": \"3.33%\"\n      }\n    }\n  }\n}"
            }
          ]
        },
        {
          "name": "Usage Analytics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/analytics?days=7",
              "host": ["{{base_url}}"],
              "path": ["analytics"],
              "query": [
                {
                  "key": "days",
                  "value": "7",
                  "description": "Number of days to analyze (1-90)"
                }
              ]
            },
            "description": "Get usage analytics. Requires authentication."
          },
          "response": [
            {
              "name": "Analytics Response",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Success\",\n  \"data\": {\n    \"period\": \"7 days\",\n    \"users\": {\n      \"total\": 150,\n      \"active\": 142,\n      \"new\": 23\n    },\n    \"auth\": {\n      \"logins\": 450,\n      \"registrations\": 23\n    },\n    \"activity_by_day\": [\n      { \"_id\": \"2026-04-08\", \"count\": 45 },\n      { \"_id\": \"2026-04-09\", \"count\": 52 }\n    ],\n    \"top_actions\": [\n      { \"action\": \"LOGIN\", \"count\": 450 },\n      { \"action\": \"PROFILE_VIEW\", \"count\": 230 }\n    ]\n  }\n}"
            }
          ]
        },
        {
          "name": "Recent Activity",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/analytics/recent?limit=20",
              "host": ["{{base_url}}"],
              "path": ["analytics", "recent"],
              "query": [
                {
                  "key": "limit",
                  "value": "20",
                  "description": "Number of records (1-100)"
                }
              ]
            },
            "description": "Get recent logins, registrations, and errors"
          },
          "response": []
        }
      ]
