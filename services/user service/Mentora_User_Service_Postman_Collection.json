              "raw": "{\n  \"refresh_token\": \"eyJhbGciOiJIUzI1NiIs...\"\n}"
            },
            "url": {
              "raw": "http://localhost:3001/api/auth/refresh",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "auth", "refresh"]
            },
            "description": "Get a new access token using refresh token"
