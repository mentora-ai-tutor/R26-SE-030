  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-set base_url if not defined",
          "if (!pm.environment.get('base_url')) {",
          "    pm.environment.set('base_url', 'http://localhost:3001');",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-save tokens from responses",
          "const jsonData = pm.response.json();",
          "if (jsonData && jsonData.data) {",
          "    if (jsonData.data.access_token) {",
          "        pm.environment.set('access_token', jsonData.data.access_token);",
          "    }",
          "    if (jsonData.data.refresh_token) {",
          "        pm.environment.set('refresh_token', jsonData.data.refresh_token);",
          "    }",
          "    if (jsonData.data.student) {",
          "        pm.environment.set('student_id', jsonData.data.student.student_id);",
          "        if (jsonData.data.student._id) {",
          "            pm.environment.set('user_id', jsonData.data.student._id);",
          "        }",
          "    }",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3001",
      "type": "string",
      "description": "Base URL for the API"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string",
      "description": "JWT access token (auto-populated after login)"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string",
      "description": "JWT refresh token (auto-populated after login)"
    },
    {
      "key": "admin_token",
      "value": "",
      "type": "string",
      "description": "Admin user JWT token"
    },
    {
      "key": "student_id",
      "value": "STD-00001",
      "type": "string",
      "description": "Student ID format: STD-XXXXX (auto-populated)"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string",
      "description": "MongoDB ObjectId (auto-populated)"
    },
    {
      "key": "session_id",
      "value": "",
      "type": "string",
      "description": "Session ID for revoke"
    },
    {
      "key": "internal_service_key",
      "value": "your-internal-service-key",
      "type": "string",
      "description": "Internal service API key from env"
    }
  ]
