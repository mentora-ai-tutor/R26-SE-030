  "item": [
    {
      "name": "n8n Workflow Tests",
      "item": [
        {
          "name": "POST /webhook/learner-profile (Direct n8n)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response status is success', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.eql('success');",
                  "    pm.expect(jsonData).to.have.property('material_id');",
                  "    pm.expect(jsonData).to.have.property('agentic_summary');",
                  "});",
                  "",
                  "pm.test('Agentic summary present', function() {",
                  "    var jsonData = pm.response.json();",
                  "    var summary = jsonData.agentic_summary;",
                  "    pm.expect(summary).to.have.property('quality_score');",
                  "    pm.expect(summary).to.have.property('validation_score');",
                  "    pm.expect(summary).to.have.property('overall_score');",
                  "    pm.expect(summary).to.have.property('agent_decision');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"student_id\": \"{{studentId}}\",\n    \"analysis_timestamp\": \"2026-04-28T10:00:00.000Z\",\n    \"mastery_profile\": {\n        \"overall_mastery_score\": 45,\n        \"knowledge_gaps\": [\n            {\n                \"topic\": \"Recursion\",\n                \"topic_id\": \"java-recursion-001\",\n                \"gap_type\": \"FUNDAMENTAL_GAP\",\n                \"misconceptions\": [\n                    \"Thinks the base case is optional\",\n                    \"Confuses stack frame with heap allocation\",\n                    \"Believes recursive calls run in parallel\"\n                ],\n                \"observed_error_patterns\": {\n                    \"missing_base_case\": 8,\n                    \"infinite_recursion\": 5,\n                    \"wrong_return_value\": 3\n                },\n                \"evidence_summary\": \"Student scored 18/60 on Recursion quiz. Submitted 8 solutions with missing base cases.\",\n                \"prerequisite_topics\": [\"Methods and return values\", \"Stack data structure basics\"],\n                \"related_topics\": [\"Binary search\", \"Tree traversal\", \"Dynamic programming\"],\n                \"suggested_intervention\": {\n                    \"primary\": \"interactive_tutorial\",\n                    \"learning_objectives\": [\n                        \"Define a correct base case for any recursive function\",\n                        \"Trace a recursive call stack manually\",\n                        \"Convert a simple loop to a recursive equivalent\"\n                    ]\n                }\n            }\n        ],\n        \"strengths\": [\n            \"Understands basic syntax\",\n            \"Can write simple loops\",\n            \"Knows variable types\"\n        ]\n    },\n    \"recommendations\": {\n        \"priority\": \"high\",\n        \"focus_areas\": [\"recursion\", \"stack memory\", \"base case identification\"]\n    },\n    \"data_sources\": {\n        \"quiz_results\": \"2026-04-28\",\n        \"code_submissions\": 15,\n        \"error_analysis\": \"Knowledge Analysis Agent\"\n    }\n}"
            },
            "url": {
              "raw": "{{n8nBaseUrl}}/webhook/learner-profile",
              "host": ["{{n8nBaseUrl}}"],
              "path": ["webhook", "learner-profile"]
            }
          },
          "response": []
        },
        {
          "name": "POST /webhook/learner-profile - Multiple Gaps",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Multiple materials generated', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.eql('success');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"student_id\": \"{{studentId}}\",\n    \"mastery_profile\": {\n        \"overall_mastery_score\": 50,\n        \"knowledge_gaps\": [\n            {\n                \"topic\": \"Recursion\",\n                \"topic_id\": \"java-recursion-001\",\n                \"gap_type\": \"FUNDAMENTAL_GAP\",\n                \"misconceptions\": [\"Thinks the base case is optional\"]\n            },\n            {\n                \"topic\": \"Arrays\",\n                \"topic_id\": \"java-arrays-002\",\n                \"gap_type\": \"PARTIAL_GAP\",\n                \"misconceptions\": [\"Confuses array indexing\"]\n            },\n            {\n                \"topic\": \"Object-Oriented Programming\",\n                \"topic_id\": \"java-oop-003\",\n                \"gap_type\": \"SURFACE_GAP\",\n                \"misconceptions\": [\"Doesn't understand inheritance\"]\n            }\n        ],\n        \"strengths\": [\"Basic Java syntax\"]\n    }\n}"
            },
            "url": {
