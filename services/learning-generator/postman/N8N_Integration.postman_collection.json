    {
      "name": "LMG Service → n8n Integration",
      "item": [
        {
          "name": "POST /api/mastery/submit (via LMG Service)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 202 Accepted', function() {",
                  "    pm.response.to.have.status(202);",
                  "});",
                  "",
                  "pm.test('Returns job_id for polling', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "    pm.expect(jsonData.data).to.have.property('job_id');",
                  "    pm.expect(jsonData.data).to.have.property('check_status_at');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"student_id\": \"{{studentId}}\",\n    \"mastery_profile\": {\n        \"overall_mastery_score\": 45,\n        \"knowledge_gaps\": [\n            {\n                \"topic\": \"Recursion\",\n                \"topic_id\": \"java-recursion-001\",\n                \"gap_type\": \"FUNDAMENTAL_GAP\",\n                \"misconceptions\": [\"Thinks the base case is optional\"]\n            }\n        ]\n    }\n}"
            },
            "url": {
              "raw": "{{lmgBaseUrl}}/api/mastery/submit",
              "host": ["{{lmgBaseUrl}}"],
              "path": ["api", "mastery", "submit"]
            }
          },
          "response": []
        },
        {
          "name": "GET /api/materials/:studentId (from MongoDB)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Returns materials with structured_material', function() {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.data.items && jsonData.data.items.length > 0) {",
                  "        var item = jsonData.data.items[0];",
                  "        pm.expect(item).to.have.property('structured_material');",
                  "        var sm = item.structured_material;",
                  "        pm.expect(sm).to.have.property('lesson');",
                  "        pm.expect(sm).to.have.property('assessment');",
                  "        pm.expect(sm).to.have.property('agentic_metadata');",
                  "        pm.expect(sm).to.have.property('quality_flags');",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{lmgBaseUrl}}/api/materials/{{studentId}}?limit=5",
              "host": ["{{lmgBaseUrl}}"],
              "path": ["api", "materials", "{{studentId}}"],
              "query": [
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "GET /api/materials/:studentId/stats",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Returns agentic stats', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "    pm.expect(jsonData.data).to.have.property('total_materials');",
                  "    pm.expect(jsonData.data).to.have.property('avg_quality_score');",
                  "    pm.expect(jsonData.data).to.have.property('avg_validation_score');",
                  "    pm.expect(jsonData.data).to.have.property('needs_review_count');",
                  "});"
                ]
              }
            }
