          "response": [
            {
              "name": "Valid Token",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"valid\": true,\n  \"student\": {\n    \"student_id\": \"STD-00001\",\n    \"name\": \"John Doe\",\n    \"email\": \"john.doe@example.com\",\n    \"role\": \"student\",\n    \"stats\": {\n      \"overall_mastery_score\": 75,\n      \"total_materials_generated\": 25,\n      \"total_sessions\": 12\n    },\n    \"is_active\": true\n  }\n}"
            },
            {
              "name": "Invalid Token",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"valid\": false,\n  \"error\": \"Token expired\"\n}"
            }
          ]
        },
