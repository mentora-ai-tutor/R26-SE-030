    {
      "name": "Health & Dependency Checks",
      "item": [
        {
          "name": "GET /api/agent/health - Full Dependency Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 or 503', function() {",
                  "    pm.expect([200, 503]).to.include(pm.response.code);",
                  "});",
                  "",
                  "pm.test('Returns all dependencies status', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.dependencies).to.have.property('mongodb');",
                  "    pm.expect(jsonData.dependencies).to.have.property('user_service');",
                  "    pm.expect(jsonData.dependencies).to.have.property('n8n');",
                  "    pm.expect(jsonData.dependencies).to.have.property('ollama');",
                  "});",
                  "",
                  "pm.test('Checks n8n status', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(['reachable', 'unreachable']).to.include(jsonData.dependencies.n8n.status);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{lmgBaseUrl}}/api/agent/health",
              "host": ["{{lmgBaseUrl}}"],
              "path": ["api", "agent", "health"]
            }
          },
          "response": []
        }
      ]
