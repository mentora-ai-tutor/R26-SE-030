              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Success\",\n  \"data\": {\n    \"student\": {\n      \"student_id\": \"STD-00001\",\n      \"name\": \"John Doe\",\n      \"email\": \"john.doe@example.com\",\n      \"role\": \"student\",\n      \"profile\": {\n        \"java_level\": \"beginner\",\n        \"institution\": \"SLIIT\",\n        \"country\": \"Sri Lanka\",\n        \"avatar_url\": \"\",\n        \"bio\": \"\"\n      },\n      \"stats\": {\n        \"overall_mastery_score\": 0,\n        \"total_materials_generated\": 0,\n        \"total_sessions\": 0,\n        \"last_mastery_update\": null\n      },\n      \"is_active\": true,\n      \"enrolled_at\": \"2026-04-14T10:30:00.000Z\",\n      \"last_active\": \"2026-04-14T10:30:00.000Z\"\n    },\n    \"access_token\": \"eyJhbGciOiJIUzI1NiIs...\",\n    \"refresh_token\": \"eyJhbGciOiJIUzI1NiIs...\",\n    \"expires_in\": \"1h\"\n  }\n}"
